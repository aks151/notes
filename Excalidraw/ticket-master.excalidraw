      "isDeleted": false,
      "boundElements": [],
      "updated": 1769927878910,
      "link": null,
      "locked": false,
      "text": "APIs\n1. GET /events -> Event[]\n2. GET /events/search/{search_query} -> Event[]\n3. POST /bookings/:eventId\n    {ticket details,\n      event details,\n    }",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "APIs\n1. GET /events -> Event[]\n2. GET /events/search/{search_query} -> Event[]\n3. POST /bookings/:eventId\n    {ticket details,\n      event details,\n    }",
      "autoResize": true,
      "lineHeight": 1.25
    },
