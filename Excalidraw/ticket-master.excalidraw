  "elements": [
    {
      "id": "s_PMspDRvV5mD1M53cSCq",
      "type": "text",
      "x": -121.34375,
      "y": 271.822265625,
      "width": 770.4993896484375,
      "height": 625,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "a2",
