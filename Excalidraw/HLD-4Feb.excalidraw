    {
      "id": "s_29VDFaRsE3jkbLFxnl4",
      "type": "text",
      "x": -120.3277847891444,
      "y": 10248.800558833313,
      "width": 585.8995971679688,
      "height": 275,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
