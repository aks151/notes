      "isDeleted": false,
      "boundElements": [],
      "updated": 1769926369805,
      "link": null,
      "locked": false,
      "text": "Core Entities\n1. User\n2. Event\n3. Performer\n4. Ticket\n5. Bookings\n6. Venue",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Core Entities\n1. User\n2. Event\n3. Performer\n4. Ticket\n5. Bookings\n6. Venue",
      "autoResize": true,
