      "type": "text",
      "x": 780.09765625,
      "y": 480.994140625,
      "width": 502.2396240234375,
      "height": 175,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
