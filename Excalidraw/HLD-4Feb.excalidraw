    {
      "id": "lsnV_CsZ77TfGz7x324eG",
      "type": "text",
      "x": 89.58913944049453,
      "y": 3826.5925859791637,
      "width": 2709.53857421875,
      "height": 3850,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b0D",
