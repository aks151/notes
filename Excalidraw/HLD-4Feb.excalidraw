    {
      "id": "_BkjGJhk_jVbJG99BgiY-",
      "type": "text",
      "x": 12.7578125,
      "y": 2516.994140625,
      "width": 1510.4990234375,
      "height": 100,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b06",
