      "isDeleted": false,
      "boundElements": null,
      "updated": 1770716613639,
      "link": null,
      "locked": false,
      "text": "FB Post Search\n\nFR\n1. Create posts\n2. Search by keywords\n3. Get search results sorted by recency\nor like count ",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "FB Post Search\n\nFR\n1. Create posts\n2. Search by keywords\n3. Get search results sorted by recency\nor like count ",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "YGrn4O-r94Uk8JELmsheu",
      "type": "text",
      "x": -2318.106008028036,
      "y": 2655.4898894552684,
      "width": 488.1196594238281,
      "height": 175,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "dashed",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b3u",
      "roundness": null,
      "seed": 580092016,
      "version": 270,
      "versionNonce": 1158904464,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1770717113732,
      "link": null,
      "locked": false,
      "text": "NFR:\n1. Highly available\n2. Low latency search <500ms\n3. High search throughput even in case\nof huge traffic\n4. All post must be discoverable\n5. New posts should be searchable within a minute",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "NFR:\n1. Highly available\n2. Low latency search <500ms\n3. High search throughput even in case\nof huge traffic\n4. All post must be discoverable\n5. New posts should be searchable within a minute",
      "autoResize": true,
      "lineHeight": 1.25
    },
