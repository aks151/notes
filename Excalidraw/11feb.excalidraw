    {
      "id": "EGjzUWOkahmiF3clHy6Jl",
      "type": "text",
      "x": -2909.3313188572383,
      "y": -741.2703570543665,
      "width": 462.67974853515625,
      "height": 175,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
