      "versionNonce": 600583615,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1770620161378,
      "link": null,
      "locked": false,
      "text": "FB News Feed - fanout and datamodelling\n\nFR:\n1. create posts\n2. show timeline in chronological order\n3. user should be able to follow each other\n4. should be able to page through their timeline",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "FB News Feed - fanout and datamodelling\n\nFR:\n1. create posts\n2. show timeline in chronological order\n3. user should be able to follow each other\n4. should be able to page through their timeline",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "Ha337t4zQ_BF7qLFnByTZ",
      "type": "text",
      "x": -2903.000573758881,
      "y": -520.5115212730593,
      "width": 887.659423828125,
      "height": 150,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b2u",
      "roundness": null,
      "seed": 2060228913,
      "version": 415,
      "versionNonce": 658700159,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1770619211314,
      "link": null,
      "locked": false,
      "text": "NFR:\n1. Availability > Consistency, should be highly available. \n2. Should handle huge users base(2B users) . We will tolerate upto 1 min of post staleness\n3. Low latency post creation and feed showing <500ms\n4. Should be able to follow and get followed by unlimited numbers of users\n",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "NFR:\n1. Availability > Consistency, should be highly available. \n2. Should handle huge users base(2B users) . We will tolerate upto 1 min of post staleness\n3. Low latency post creation and feed showing <500ms\n4. Should be able to follow and get followed by unlimited numbers of users\n",
      "autoResize": true,
      "lineHeight": 1.25
    },
