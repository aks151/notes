      "boundElements": null,
      "updated": 1770618751394,
      "link": null,
      "locked": false,
      "text": "HLD\n1. Users should be able to create posts\n2. Should be able to follow each other\n3. Users should be able to see the feeds of\nposts from the users they follow\n4. Users should be able to page through\ntheir feed",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "HLD\n1. Users should be able to create posts\n2. Should be able to follow each other\n3. Users should be able to see the feeds of\nposts from the users they follow\n4. Users should be able to page through\ntheir feed",
      "autoResize": true,
      "lineHeight": 1.25
    },
