    {
      "id": "tgF6eSXawRJHw9MBXZMPB",
      "type": "text",
      "x": -2340.266813161746,
      "y": 704.2837612539479,
      "width": 601.57958984375,
      "height": 375,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b3c",
      "roundness": null,
      "seed": 1117759391,
      "version": 587,
      "versionNonce": 1440017983,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1770618715038,
      "link": null,
      "locked": false,
      "text": "Feed\n\nto get a feed for a user\nwe can first get all the users\nthey follow by querying the follow db\nthen we can get all the list of the posts\nby the users and then we can sort it \nchronologically and return this feed. \n\nYes this is an inefficient query, and the first\nthing we can do is make a GSI on createdBy key\nin the posts table so that we can query the posts efficiently\nby the userid who created it\n\nI will come to improve this design when i deep dive",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Feed\n\nto get a feed for a user\nwe can first get all the users\nthey follow by querying the follow db\nthen we can get all the list of the posts\nby the users and then we can sort it \nchronologically and return this feed. \n\nYes this is an inefficient query, and the first\nthing we can do is make a GSI on createdBy key\nin the posts table so that we can query the posts efficiently\nby the userid who created it\n\nI will come to improve this design when i deep dive",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "SDF8K7yDtJ6rOk9b0WgGk",
      "type": "text",
      "x": -2954.4376982959584,
      "y": 937.4998533753596,
      "width": 441.05975341796875,
      "height": 225,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b3d",
      "roundness": null,
      "seed": 1880644735,
      "version": 203,
      "versionNonce": 1193932319,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1770619027966,
      "link": null,
      "locked": false,
      "text": "Page through feed\n\nwe can keep track of the \ntimestamp of the last post that was\nloaded in the timeline and thus we can\nrequest for posts older than that timestamp\n\n\n",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Page through feed\n\nwe can keep track of the \ntimestamp of the last post that was\nloaded in the timeline and thus we can\nrequest for posts older than that timestamp\n\n\n",
      "autoResize": true,
      "lineHeight": 1.25
    },
